@page
@model IndexModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var canonicalBase = Configuration["CanonicalBaseUrl"] ?? "https://moritafight.com.br/";
    ViewData["Title"] = "Morita - Equipamentos para Artes Marciais em Sorocaba";
    ViewData["Description"] = "Equipamentos para Jiu-Jitsu e Muay Thai em Sorocaba. Kimonos, luvas, rashguards, shorts e acessórios com atendimento pelo WhatsApp e retirada na loja.";
    ViewData["OgTitle"] = "Morita | Artes Marciais em Sorocaba";
    ViewData["OgDescription"] = "Kimonos, luvas, rashguards, shorts e acessórios para Jiu-Jitsu e Muay Thai em Sorocaba.";
    ViewData["BodyClass"] = "home-page";
}

@section Header {
<script type="application/ld+json">
  {
    "@@context": "https://schema.org",
    "@@type": "SportingGoodsStore",
    "name": "Morita",
    "url": "@(canonicalBase)",
    "image": "@($"{canonicalBase.TrimEnd('/')}/images/favicon.png")",
    "logo": "@($"{canonicalBase.TrimEnd('/')}/images/favicon.png")",
    "telephone": "+55-15-98107-9332",
    "address": {
      "@@type": "PostalAddress",
      "streetAddress": "Rua Coronel Nogueira Padilha, 429",
      "addressLocality": "Sorocaba",
      "addressRegion": "SP",
      "postalCode": "18020-000",
      "addressCountry": "BR"
    },
    "openingHours": ["Mo-Fr 09:00-18:00", "Sa 09:00-13:00"],
    "areaServed": "Sorocaba - SP",
    "priceRange": "$$",
    "sameAs": [
      "https://www.instagram.com/morita.fight/"
    ]
  }
</script>
}

<main class="home-main">
    <section class="home-hero" aria-labelledby="home-title">
      <div class="home-hero-copy">
        <img src="~/images/logo.png" alt="Morita" class="home-logo">
        <p class="eyebrow">Loja de artes marciais em Sorocaba</p>
        <h1 id="home-title">Equipamentos certos para o seu treino em Sorocaba</h1>
        <p class="hero-lead">Jiu-Jitsu e Muay Thai com atendimento direto para escolher tamanho, modelo e disponibilidade, seja para começar, treinar melhor ou competir.</p>
        <div class="hero-actions">
          <a class="button whatsapp primary-cta" href="https://wa.me/c/5515981079332" target="_blank" rel="noopener noreferrer" aria-label="Abrir catálogo da Morita no WhatsApp" data-track-event="whatsapp_catalog_click" data-track-category="home">
            <i class="fas fa-phone"></i>
            Falar no WhatsApp
          </a>
          <button class="button request-hero-cta" type="button" data-request-open data-track-event="customer_product_request_open" data-track-category="home">
            <i class="fas fa-magnifying-glass"></i>
            Encontrar meu tamanho
          </button>
          <a class="button instagram secondary-cta" href="https://www.instagram.com/morita.fight/" target="_blank" rel="noopener noreferrer" aria-label="Abrir Instagram da Morita" data-track-event="instagram_click" data-track-category="home">
            <i class="fab fa-instagram"></i>
            Instagram
          </a>
        </div>
        <a class="address home-address" href="https://maps.app.goo.gl/pNYYiMimWGa4actz7" data-track-event="store_location_click" data-track-category="home">
          <i class="fas fa-location-dot"></i>
          Rua Coronel Nogueira Padilha, 429 - Sorocaba, SP
        </a>
        <ul class="trust-list" aria-label="Diferenciais da Morita">
          <li>Loja física em Sorocaba</li>
          <li>Ajuda para escolher tamanho</li>
          <li>Atendimento rápido em Sorocaba e região</li>
          <li>Retirada ou envio</li>
        </ul>
      </div>
      <div class="home-hero-media" aria-hidden="true">
        <img src="~/images/kimono/adulto/itg-azul.jpg" alt="" class="hero-product hero-product-main">
        <img src="~/images/muay-thai/luva-st.jpg" alt="" class="hero-product hero-product-accent">
      </div>
    </section>

    <section class="category-section" aria-labelledby="category-title">
      <p class="eyebrow">Escolha sua modalidade</p>
      <h2 id="category-title">Encontre o equipamento certo para o seu treino</h2>
      <div class="category-grid">
        <a href="/JiuJitsu" class="category-card category-card-jiu" data-track-event="category_navigation_click" data-track-category="home" data-track-selected-category="jiu-jitsu">
          <img src="~/images/kimono/adulto/itg-branco.jpeg" alt="Kimono de Jiu-Jitsu Morita">
          <span class="category-card-content">
            <span class="category-kicker">Jiu-Jitsu</span>
            <strong>Kimonos, rashguards e faixas</strong>
            <span>Ver produtos</span>
          </span>
        </a>
        <a href="/MuayThai" class="category-card category-card-muay" data-track-event="category_navigation_click" data-track-category="home" data-track-selected-category="muay-thai">
          <img src="~/images/muay-thai/shorts-varios.jpg" alt="Shorts e equipamentos de Muay Thai Morita">
          <span class="category-card-content">
            <span class="category-kicker">Muay Thai</span>
            <strong>Luvas, shorts e caneleiras</strong>
            <span>Ver produtos</span>
          </span>
        </a>
      </div>
    </section>
</main>

<section class="random-products-section" aria-labelledby="random-products-title">
  <p class="eyebrow">Produtos em destaque</p>
  <h2 id="random-products-title">Um giro pelo catálogo Morita</h2>
  <div class="random-carousel">
    @for (var i = 0; i < Model.Slides.Count; i++)
    {
        var slide = Model.Slides[i];
        <a href="@slide.CategoryUrl" class="random-carousel-slide @(i == 0 ? "active" : "")" data-track-event="category_navigation_click" data-track-category="home-carousel" data-track-selected-category="@slide.CategoryName.ToLower().Replace(" ", "-")">
          <img src="@slide.Image" class="random-carousel-img" alt="Produto de @slide.CategoryName Morita">
          <span class="random-carousel-caption">
            <span>@slide.CategoryName</span>
            <strong>Ver produtos</strong>
          </span>
        </a>
    }
    <button class="random-carousel-btn prev" type="button" onclick="navigateRandomCarousel(-1)" aria-label="Produto anterior">&#10094;</button>
    <button class="random-carousel-btn next" type="button" onclick="navigateRandomCarousel(1)" aria-label="Próximo produto">&#10095;</button>
  </div>
</section>

@section Scripts {
<script>
  let currentRandomImageIndex = 0;

  function navigateRandomCarousel(direction) {
    const slides = document.querySelectorAll('.random-carousel-slide');
    if (!slides.length) return;

    slides[currentRandomImageIndex].classList.remove('active');
    currentRandomImageIndex = (currentRandomImageIndex + direction + slides.length) % slides.length;
    slides[currentRandomImageIndex].classList.add('active');
  }

  window.navigateRandomCarousel = navigateRandomCarousel;
</script>
}
