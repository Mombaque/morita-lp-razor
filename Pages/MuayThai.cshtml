@page
@model MuayThaiModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var canonicalBase = Configuration["CanonicalBaseUrl"] ?? "https://moritafight.com.br/";
    ViewData["Title"] = "Equipamentos de Muay Thai e Boxe Sorocaba | Luvas e Shorts";
    ViewData["Description"] = "Na Morita em Sorocaba, você compra luvas de Muay Thai e Boxe, bandagens, protetores bucais, caneleiras e shorts tailandeses com excelente preço. Atendimento pelo WhatsApp para acertar no tamanho e retirar na loja. Confira os modelos!";
    ViewData["OgTitle"] = "Equipamentos Muay Thai e Boxe | Sorocaba";
    ViewData["OgDescription"] = "Luvas de Muay Thai e Boxe de 12oz, 14oz e 16oz, shorts tailandeses e acessórios. Retire no Nogueira Padilha ou receba em Sorocaba.";
    ViewData["BodyClass"] = "category-page muay-thai-page";
}

@section Header {
  <meta name="keywords" content="morita fight, morita fitness, loja de artes marciais sorocaba, equipamentos de muay thai sorocaba, equipamentos de boxe sorocaba, luva de boxe sorocaba, luva de muay thai sorocaba, shorts de muay thai sorocaba, bandagem sorocaba, protetor bucal sorocaba, caneleira sorocaba, comprar luva de boxe, comprar shorts muay thai, luva 12oz sorocaba, luva 14oz sorocaba, luva 16oz sorocaba, loja nogueira padilha, artes marciais em sorocaba">
  <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "SportingGoodsStore",
      "name": "Morita Muay Thai & Boxe Sorocaba",
      "url": "@(canonicalBase)",
      "image": "@($"{canonicalBase.TrimEnd('/')}/images/favicon.png")",
      "logo": "@($"{canonicalBase.TrimEnd('/')}/images/favicon.png")",
      "telephone": "+55-15-98107-9332",
      "address": {
        "@@type": "PostalAddress",
        "streetAddress": "Rua Coronel Nogueira Padilha, 429",
        "addressLocality": "Sorocaba",
        "addressRegion": "SP",
        "postalCode": "18020-000",
        "addressCountry": "BR"
      },
      "openingHours": ["Mo-Fr 09:00-18:00", "Sa 09:00-13:00"],
      "areaServed": "Sorocaba - Nogueira Padilha",
      "priceRange": "$$",
      "sameAs": [
        "https://www.instagram.com/morita.fight"
      ]
    }
  </script>
}

<header class="category-header">
    <img class="logo" src="~/images/logo.png" alt="Morita Fitness">
</header>

<main class="category-main">
    <section class="category-hero" aria-labelledby="category-title">
      <div class="category-hero-copy">
        <p class="eyebrow">Muay Thai / Boxe em Sorocaba</p>
        <h1 id="category-title">Luvas, shorts e caneleiras para o seu treino</h1>
        <p class="category-lead">
          Equipamentos confortáveis e resistentes para treinar forte, com ajuda no WhatsApp para escolher tamanho e modelo.
        </p>
        <div class="hero-actions">
          <a class="button whatsapp primary-cta" href="https://wa.me/c/5515981079332" target="_blank" rel="noopener noreferrer" aria-label="Abrir catálogo de Muay Thai da Morita Fitness no WhatsApp" data-track-event="whatsapp_catalog_click" data-track-category="muay-thai">
            <i class="fas fa-phone"></i>
            Falar no WhatsApp
          </a>
          <button class="button request-hero-cta" type="button" data-request-open data-track-event="customer_product_request_open" data-track-category="muay-thai">
            <i class="fas fa-magnifying-glass"></i>
            Encontrar meu tamanho
          </button>
          <a class="button instagram secondary-cta" href="https://www.instagram.com/morita.fight/" target="_blank" rel="noopener noreferrer" aria-label="Instagram Morita Fitness" data-track-event="instagram_click" data-track-category="muay-thai">
            <i class="fab fa-instagram"></i>
            Instagram
          </a>
        </div>
        <ul class="trust-list" aria-label="Diferenciais para Muay Thai">
          <li>Loja física em Sorocaba</li>
          <li>Ajuda na escolha do tamanho</li>
          <li>Atendimento em Sorocaba e região</li>
          <li>Retirada ou envio</li>
        </ul>
      </div>
      <div class="category-hero-media" aria-hidden="true">
        <img src="~/images/muay-thai/luva-st.jpg" alt="" class="category-hero-img category-hero-img-main">
        <img src="~/images/muay-thai/short-thailandia.png" alt="" class="category-hero-img category-hero-img-accent">
      </div>
    </section>

    <section class="quick-nav" aria-label="Categorias de Muay Thai">
      <span>Luvas</span>
      <span>Shorts</span>
      <span>Caneleiras</span>
      <span>Acessórios</span>
    </section>

    <section class="products-intro" aria-labelledby="products-title">
      <p class="eyebrow">Catálogo</p>
      <h2 id="products-title">Produtos de Muay Thai e Boxe</h2>
    </section>

    <section id="products" class="products" data-track-category="muay-thai">
        @for (var index = 0; index < Model.Products.Count; index++)
        {
            var p = Model.Products[index];
            var cleanName = System.Text.RegularExpressions.Regex.Replace(p.Nome.ToLower(), @"[^\w-]", "");
            var carouselId = $"carousel-{cleanName}-{index}";
            var shuffledImagens = p.Imagens.OrderBy(_ => Random.Shared.Next()).ToList();

            <div class="product">
                <div class="carousel" id="@carouselId">
                    @if (shuffledImagens.Count == 0)
                    {
                        <img src="https://via.placeholder.com/300x300.png?text=Produto+sem+imagem" alt="@p.Alt" class="carousel-img active">
                    }
                    else
                    {
                        @for (var i = 0; i < shuffledImagens.Count; i++)
                        {
                            <img src="@Url.Content("~" + shuffledImagens[i])" alt="@p.Alt" class="carousel-img @(i == 0 ? "active" : "")" data-index="@i">
                        }
                    }
                    @if (shuffledImagens.Count > 1)
                    {
                        <button class="prev" onclick="getImage('@carouselId', false)">&#10094;</button>
                        <button class="next" onclick="getImage('@carouselId', true)">&#10095;</button>
                    }
                </div>
                <h3>@p.Nome</h3>
                <p>@p.Descricao</p>
                <button class="product-cta" type="button" aria-label="Consultar disponibilidade de @p.Nome" data-request-open data-track-event="customer_product_request_open" data-track-category="muay-thai" data-track-selected-category="@p.Nome">
                    <i class="fas fa-magnifying-glass"></i>
                    Consultar disponibilidade
                </button>
            </div>
        }
    </section>
</main>

@section Scripts {
<script src="~/js/carousel.js" asp-append-version="true"></script>
}
