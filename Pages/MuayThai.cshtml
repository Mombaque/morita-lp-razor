@page
@model MuayThaiModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var canonicalBase = Configuration["CanonicalBaseUrl"] ?? "https://moritafight.com.br/";
    ViewData["Title"] = "Equipamentos de Muay Thai e Boxe Sorocaba | Luvas e Shorts";
    ViewData["Description"] = "Na Morita em Sorocaba, você compra luvas de Muay Thai e Boxe, bandagens, protetores bucais, caneleiras e shorts tailandeses com excelente preço. Atendimento pelo WhatsApp para acertar no tamanho e retirar na loja. Confira os modelos!";
    ViewData["OgTitle"] = "Equipamentos Muay Thai e Boxe | Sorocaba";
    ViewData["OgDescription"] = "Luvas de Muay Thai e Boxe de 12oz, 14oz e 16oz, shorts tailandeses e acessórios. Retire no Nogueira Padilha ou receba em Sorocaba.";
    ViewData["BodyClass"] = "category-page muay-thai-page";
}

@section Header {
  <meta name="keywords" content="morita, loja de artes marciais sorocaba, equipamentos de muay thai sorocaba, equipamentos de boxe sorocaba, luva de boxe sorocaba, luva de muay thai sorocaba, shorts de muay thai sorocaba, bandagem sorocaba, protetor bucal sorocaba, caneleira sorocaba, comprar luva de boxe, comprar shorts muay thai, luva 12oz sorocaba, luva 14oz sorocaba, luva 16oz sorocaba, loja nogueira padilha, artes marciais em sorocaba">
  <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "SportingGoodsStore",
      "name": "Morita Muay Thai & Boxe Sorocaba",
      "url": "@(canonicalBase)",
      "image": "@(canonicalBase.TrimEnd('/'))/images/favicon.png",
      "logo": "@(canonicalBase.TrimEnd('/'))/images/favicon.png",
      "telephone": "+55-15-98107-9332",
      "address": { "@@type": "PostalAddress", "streetAddress": "Rua Coronel Nogueira Padilha, 429", "addressLocality": "Sorocaba", "addressRegion": "SP", "postalCode": "18020-000", "addressCountry": "BR" },
      "openingHours": ["Mo-Fr 09:00-18:00", "Sa 09:00-13:00"],
      "areaServed": "Sorocaba - Nogueira Padilha",
      "priceRange": "$$",
      "sameAs": ["https://www.instagram.com/morita.fight/"]
    }
  </script>
}

<header class="category-header"><img class="logo" src="~/images/logo.png" alt="Morita"></header>

<main class="category-main">
    <section class="category-hero" aria-labelledby="category-title">
      <div class="category-hero-copy">
        <p class="eyebrow">Muay Thai / Boxe em Sorocaba</p>
        <h1 id="category-title">Luvas, shorts e caneleiras para o seu treino</h1>
        <p class="category-lead">Equipamentos confortáveis e resistentes para treinar forte, com ajuda no WhatsApp para escolher tamanho e modelo.</p>
        <div class="hero-actions">
          <a class="button whatsapp primary-cta" href="https://wa.me/c/5515981079332" target="_blank" rel="noopener noreferrer" aria-label="Abrir catálogo de Muay Thai da Morita no WhatsApp" data-track-event="whatsapp_catalog_click" data-track-category="muay-thai"><i class="fas fa-phone"></i> Falar no WhatsApp</a>
          <button class="button request-hero-cta" type="button" data-request-open data-track-event="customer_product_request_open" data-track-category="muay-thai"><i class="fas fa-magnifying-glass"></i> Encontrar meu tamanho</button>
          <a class="button instagram secondary-cta" href="https://www.instagram.com/morita.fight/" target="_blank" rel="noopener noreferrer" aria-label="Instagram Morita" data-track-event="instagram_click" data-track-category="muay-thai"><i class="fab fa-instagram"></i> Instagram</a>
        </div>
        <ul class="trust-list" aria-label="Diferenciais para Muay Thai"><li>Loja física em Sorocaba</li><li>Ajuda na escolha do tamanho</li><li>Atendimento em Sorocaba e região</li><li>Retirada ou envio</li></ul>
      </div>
      <div class="category-hero-media" aria-hidden="true">
        <img src="~/images/muay-thai/luva-st.jpg" alt="" class="category-hero-img category-hero-img-main">
        <img src="~/images/muay-thai/short-thailandia.png" alt="" class="category-hero-img category-hero-img-accent">
      </div>
    </section>

    <section class="quick-nav" aria-label="Categorias de Muay Thai"><span>Luvas</span><span>Shorts</span><span>Caneleiras</span><span>Acessórios</span></section>
    <section class="products-intro" aria-labelledby="products-title"><p class="eyebrow">Catálogo</p><h2 id="products-title">Produtos de Muay Thai e Boxe</h2></section>

    @if (Model.IsCatalogUnavailable)
    {
      <section class="product-not-found catalog-unavailable"><p class="eyebrow">Catálogo indisponível</p><h2>Não foi possível carregar os produtos agora.</h2><p>Fale com a Morita pelo WhatsApp para consultar modelos, tamanhos e valores.</p><div class="hero-actions"><a class="button whatsapp primary-cta" href="https://wa.me/c/5515981079332" target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a></div></section>
    }
    else
    {
      <section id="products" class="products" data-track-category="muay-thai">
        @for (var index = 0; index < Model.Products.Count; index++)
        {
            @await Html.PartialAsync("Shared/_ProductCard", new Morita.LP.Razor.Models.ProductCardViewModel { Product = Model.Products[index], TrackingCategory = "muay-thai", Index = index })
        }
      </section>
    }
</main>

@section Scripts {
<script src="~/js/carousel.js" asp-append-version="true"></script>
}
