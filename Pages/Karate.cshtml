@page
@model KarateModel
@inject Microsoft.Extensions.Configuration.IConfiguration Configuration
@{
    var canonicalBase = Configuration["CanonicalBaseUrl"] ?? "https://moritafight.com.br/";
    ViewData["Title"] = "Kimonos de Karatê em Sorocaba | Morita";
    ViewData["Description"] = "Kimonos de Karatê Haganah na Morita em Sorocaba. Consulte tamanhos, disponibilidade e atendimento pelo WhatsApp.";
    ViewData["OgTitle"] = "Kimonos de Karatê | Sorocaba";
    ViewData["OgDescription"] = "Kimonos para treino de Karatê com atendimento pelo WhatsApp e retirada na loja em Sorocaba.";
    ViewData["BodyClass"] = "category-page karate-page";
}

@section Header {
  <script type="application/ld+json">
    {
      "@@context": "https://schema.org",
      "@@type": "SportingGoodsStore",
      "name": "Morita Karatê Sorocaba",
      "url": "@(canonicalBase)",
      "image": "@(canonicalBase.TrimEnd('/'))/images/favicon.png",
      "logo": "@(canonicalBase.TrimEnd('/'))/images/favicon.png",
      "telephone": "+55-15-98107-9332",
      "address": { "@@type": "PostalAddress", "streetAddress": "Rua Coronel Nogueira Padilha, 429", "addressLocality": "Sorocaba", "addressRegion": "SP", "postalCode": "18020-000", "addressCountry": "BR" },
      "openingHours": ["Mo-Fr 09:00-18:00", "Sa 09:00-13:00"],
      "areaServed": "Sorocaba - Nogueira Padilha",
      "priceRange": "$$",
      "sameAs": ["https://www.instagram.com/morita.fight/"]
    }
  </script>
}

<header class="category-header"><img class="logo" src="~/images/logo.png" alt="Morita"></header>

<main class="category-main">
    <section class="category-hero" aria-labelledby="category-title">
      <div class="category-hero-copy">
        <p class="eyebrow">Karatê em Sorocaba</p>
        <h1 id="category-title">Kimonos para treinar com conforto e resistência</h1>
        <p class="category-lead">Consulte tamanhos e disponibilidade de kimonos de Karatê com atendimento direto da Morita.</p>
        <div class="hero-actions">
          <a class="button whatsapp primary-cta" href="https://wa.me/c/5515981079332" target="_blank" rel="noopener noreferrer" aria-label="Abrir catálogo da Morita no WhatsApp" data-track-event="whatsapp_catalog_click" data-track-category="karate"><i class="fas fa-phone"></i> Falar no WhatsApp</a>
          <button class="button request-hero-cta" type="button" data-request-open data-track-event="customer_product_request_open" data-track-category="karate"><i class="fas fa-magnifying-glass"></i> Encontrar meu tamanho</button>
        </div>
      </div>
      <div class="category-hero-media" aria-hidden="true">
        <img src="~/images/kimono/adulto/itg-branco.jpeg" alt="" class="category-hero-img category-hero-img-main">
        <img src="~/images/logo.png" alt="" class="category-hero-img category-hero-img-accent">
      </div>
    </section>

    <section class="quick-nav" aria-label="Categorias de Karatê"><span>Kimonos</span><span>Adulto</span><span>Haganah</span></section>
    <section class="products-intro" aria-labelledby="products-title"><p class="eyebrow">Catálogo</p><h2 id="products-title">Produtos de Karatê</h2></section>

    @if (Model.IsCatalogUnavailable)
    {
      <section class="product-not-found catalog-unavailable"><p class="eyebrow">Catálogo indisponível</p><h2>Não foi possível carregar os produtos agora.</h2><p>Fale com a Morita pelo WhatsApp para consultar modelos, tamanhos e valores.</p><div class="hero-actions"><a class="button whatsapp primary-cta" href="https://wa.me/c/5515981079332" target="_blank" rel="noopener noreferrer">Falar no WhatsApp</a></div></section>
    }
    else
    {
      <section id="products" class="products" data-track-category="karate">
        @for (var index = 0; index < Model.Products.Count; index++)
        {
            @await Html.PartialAsync("Shared/_ProductCard", new Morita.LP.Razor.Models.ProductCardViewModel { Product = Model.Products[index], TrackingCategory = "karate", Index = index })
        }
      </section>
    }
</main>

@section Scripts {
<script src="~/js/carousel.js" asp-append-version="true"></script>
}
